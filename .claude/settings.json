{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(make up)",
      "Bash(make down)",
      "Bash(make logs)",
      "Bash(make test)",
      "Bash(make minikube-start)",
      "Bash(make helm-status)",
      "Bash(make helm-install)",
      "Bash(kubectl get:*)",
      "Bash(kubectl describe:*)",
      "Bash(kubectl logs:*)",
      "Bash(kubectl top:*)",
      "Bash(kubectl events:*)",
      "Bash(helm lint:*)",
      "Bash(helm template:*)",
      "Bash(helm diff:*)",
      "Bash(helm status:*)",
      "Bash(helm list:*)",
      "Bash(az account show:*)",
      "Bash(az group list:*)",
      "Bash(az aks show:*)",
      "Bash(az aks list:*)",
      "Bash(az resource list:*)",
      "Bash(docker compose ps:*)",
      "Bash(docker compose logs:*)",
      "Bash(docker ps:*)",
      "Bash(curl -sf http://localhost:*)",
      "Bash(minikube status:*)",
      "Bash(pip install:*)",
      "Bash(python:*)",
      "Bash(az costmanagement query:*)",
      "Bash(az acr show-usage:*)",
      "Bash(az role assignment list:*)",
      "Bash(helm repo add chaos-mesh:*)",
      "Bash(helm repo update chaos-mesh)",
      "Bash(helm upgrade --install chaos-mesh:*)",
      "Bash(helm uninstall chaos-mesh:*)"
    ],
    "deny": [
      "Bash(kubectl delete:*)",
      "Bash(kubectl apply:*)",
      "Bash(kubectl rollout restart:*)",
      "Bash(helm upgrade --install mcp-stack:*)",
      "Bash(helm upgrade --install ingress-nginx:*)",
      "Bash(helm upgrade --install cert-manager:*)",
      "Bash(helm upgrade --install kube-prom:*)",
      "Bash(helm uninstall mcp-stack:*)",
      "Bash(helm uninstall ingress-nginx:*)",
      "Bash(helm uninstall cert-manager:*)",
      "Bash(helm uninstall kube-prom:*)",
      "Bash(helm install:*)",
      "Bash(az * create:*)",
      "Bash(az * delete:*)",
      "Bash(az * update:*)",
      "Bash(az role assignment create:*)",
      "Bash(git push origin main:*)",
      "Bash(git push origin main)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(rm -rf:*)"
    ]
  }
}