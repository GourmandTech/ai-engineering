# ContextForge Local Dev — Environment Variables
# Copy this file to .env and fill in your values
#
#   cp .env.example .env
#
# .env is gitignored — never commit it.

# ── Database ─────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme

# ── Auth secrets — generate strong values for anything beyond your laptop ──
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=local-dev-jwt-secret-change-me-32chars
AUTH_ENCRYPTION_SECRET=local-dev-salt-change-me

# ── Admin UI login ────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme
DEFAULT_USER_PASSWORD=changeme

# ── Optional: skip DB migrations after first successful start ─
# Set to true to speed up restarts once the schema is in place
MCPGATEWAY_SKIP_MIGRATIONS=false
